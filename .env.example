# ─── Harmonia (client website) · environment ───
# Copy to `.env.local` for local dev. In prod set these as the service's
# environment variables. The website has NO backend of its own — every
# read/write goes to the admin's public API over HTTP.

# Base URL of the admin's PUBLIC API. Local dev: the admin on :3100.
# In prod: the deployed admin URL + /api/public, e.g.
# https://harmonia-admin.up.railway.app/api/public
NEXT_PUBLIC_API_URL="http://localhost:3100/api/public"

# Tenant the website represents (sent as x-tenant-slug on every request).
NEXT_PUBLIC_TENANT_SLUG="marrakech-luxury"
